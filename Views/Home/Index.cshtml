@{
    ViewData["Title"] = "The Arsenal";
}

<style>
    /* Assassin's Creed Style Image Effects */
    .vehicle-container {
        position: relative;
        overflow: hidden;
        background: #000;
        border-bottom: 3px solid #333;
    }

    .vehicle-img {
        height: 250px;
        width: 100%;
        object-fit: cover;
        filter: grayscale(40%) brightness(80%);
        transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), filter 0.4s ease;
    }

    .card:hover .vehicle-img {
        filter: grayscale(0%) brightness(110%);
        transform: scale(1.1);
    }

    /* Red blade glow on hover */
    .card-ninja-warrior {
        transition: all 0.4s ease;
        border: 1px solid #222 !important;
    }

        .card-ninja-warrior:hover {
            border-color: #8e0000 !important;
            box-shadow: 0 0 25px rgba(142, 0, 0, 0.5);
        }
</style>

<div class="container text-center mt-5">
    <h1 class="display-4 text-uppercase mb-2" style="font-family: 'Orbitron'; color: #8e0000; letter-spacing: 5px;">The Black Arsenal</h1>
    <p class="lead mb-5 text-muted" style="font-style: italic;">"Nothing is True, Everything is Permitted... especially performance."</p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card card-ninja-warrior bg-dark text-white h-100" style="clip-path: polygon(0 0, 100% 0, 100% 92%, 92% 100%, 0 100%);">
                <div class="vehicle-container">
                    <img src="https://img.etb2bimg.com/imgv2/width-368,height-311,resize_mode-1/retail_files/defender-1661253599-prod-var.jpg" class="vehicle-img" alt="Defender">
                </div>
                <div class="card-body">
                    <h3 class="card-title mt-2" style="font-family: 'Orbitron'; color: #b1b1b1;">DEFENDER</h3>
                    <p class="small text-danger" style="letter-spacing: 2px;">MATTE BLACK EDITION</p>
                    <p class="card-text text-secondary">The ultimate tactical SUV. Silent, rugged, and unstoppable.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-ninja-warrior bg-dark text-white h-100" style="clip-path: polygon(0 0, 100% 0, 100% 92%, 92% 100%, 0 100%);">
                <div class="vehicle-container">
                    <img src="https://stimg.cardekho.com/images/carexteriorimages/630x420/Ford/Endeavour/11580/1710203310359/front-left-side-47.jpg?tr=w-664" class="vehicle-img" alt="Endeavour">
                </div>
                <div class="card-body">
                    <h3 class="card-title mt-2" style="font-family: 'Orbitron'; color: #b1b1b1;">ENDEAVOUR</h3>
                    <p class="small text-danger" style="letter-spacing: 2px;">NIGHT OPS EDITION</p>
                    <p class="card-text text-secondary">A powerhouse built for those who lead from the shadows.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-ninja-warrior bg-dark text-white h-100" style="clip-path: polygon(0 0, 100% 0, 100% 92%, 92% 100%, 0 100%);">
                <div class="vehicle-container">
                    <img src="https://static-cdn.cars24.com/prod/auto-news24-cms/Newsroom/2025/02/13/e85b7b41-0dfd-4022-9b7f-0d9baee44018-2025-tata-safari-stealth-edition-design-front-tata.webp?w=276&dpr=3&optimize=low&format=auto&quality=50" class="vehicle-img" alt="Safari">
                </div>
                <div class="card-body">
                    <h3 class="card-title mt-2" style="font-family: 'Orbitron'; color: #b1b1b1;">SAFARI</h3>
                    <p class="small text-danger" style="letter-spacing: 2px;">STEALTH EDITION</p>
                    <p class="card-text text-secondary">Modern engineering meets legendary warrior spirit.</p>
                </div>
            </div>
        </div>
    </div>
</div>