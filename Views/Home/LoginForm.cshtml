@model WebApplication1.Models.Entities.Clients

@{
    ViewData["Title"] = "Identify";
}

<style>
    /* ... Your existing styles ... */
    .auth-overlay {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #000;
        position: relative;
    }

    .terminal-box {
        background: rgba(10, 10, 10, 0.9);
        border: 1px solid #333;
        border-right: 4px solid #8e0000;
        padding: 3rem;
        width: 100%;
        max-width: 420px;
        position: relative;
        box-shadow: 0 0 30px rgba(142, 0, 0, 0.2);
        clip-path: polygon(5% 0, 100% 0, 100% 95%, 95% 100%, 0 100%, 0 5%);
    }

    .terminal-title {
        font-family: 'Orbitron', sans-serif;
        color: #8e0000;
        letter-spacing: 5px;
        text-shadow: 0 0 10px rgba(142, 0, 0, 0.5);
    }

    /* Error Alert Styling */
    .system-error {
        background: rgba(142, 0, 0, 0.1);
        border-left: 3px solid #ff0000;
        color: #ff4d4d;
        padding: 12px;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.7rem;
        margin-bottom: 20px;
        letter-spacing: 1px;
        text-transform: uppercase;
        animation: glitch-flash 0.3s ease;
    }

    .form-group-ninja label {
        display: block;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.75rem;
        color: #b1b1b1;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .ninja-field {
        width: 100%;
        background: #111;
        border: 1px solid #444;
        color: #fff;
        padding: 12px 15px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        border-radius: 0;
    }

        .ninja-field:focus {
            outline: none;
            border-color: #8e0000;
            background: #1a1a1a;
            box-shadow: inset 0 0 5px rgba(142, 0, 0, 0.5);
        }

    .btn-decrypt {
        width: 100%;
        background: #8e0000;
        color: #fff;
        border: none;
        padding: 14px;
        font-family: 'Orbitron', sans-serif;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 3px;
        cursor: pointer;
        transition: 0.4s;
    }

        .btn-decrypt:hover {
            background: #fff;
            color: #8e0000;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
        }

    /* Animation for the Error */
    @@keyframes glitch-flash {
        0% {
            transform: translateX(-5px);
            filter: hue-rotate(90deg);
        }

        20% {
            transform: translateX(5px);
        }

        40% {
            transform: translateX(-5px);
        }

        60% {
            transform: translateX(5px);
        }

        100% {
            transform: translateX(0);
        }
    }
</style>

<div class="auth-overlay">
    <div class="terminal-box">
        <div class="text-center mb-5">
            <h2 class="terminal-title">IDENTIFY</h2>
            <p class="small text-muted" style="letter-spacing: 2px;">SYNCING WITH BROTHERHOOD</p>
        </div>

        @if (TempData["LoginFailed"] != null)
        {
        <div class="system-error">
            <i class="fas fa-exclamation-triangle"></i> ALERT: @TempData["LoginFailed"]
        </div>
        }

        <form asp-controller="Register" asp-action="LoginCheck" method="POST">
            <div class="form-group-ninja">
                <label for="identity">Email Address</label>
                <input type="text" id="identity" name="Identity" class="ninja-field" placeholder="brothe@google.com/ OR /phone" required>
            </div>

            <div class="form-group-ninja">
                <label for="pass">Encryption Key</label>
                <input type="password" id="pass" name="Password" class="ninja-field" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn-decrypt">Synchronize</button>

            <div class="links-footer text-center mt-4">
                <a href="/Home/ClientRegister" style="color:#555; text-decoration:none; font-size:0.8rem;">Request New Identity</a>
                <span class="mx-2 text-muted">|</span>
                <a href="/Home/Index" style="color:#555; text-decoration:none; font-size:0.8rem;">Abandon Mission</a>
            </div>
        </form>
    </div>
</div>