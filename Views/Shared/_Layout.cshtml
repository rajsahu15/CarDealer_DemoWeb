<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ninja Warriors</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Orbitron:wght@400;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --assassin-red: #8e0000;
            --animus-dark: #0a0a0a;
            --steel-gray: #e0e0e0;
            --blade-silver: #b1b1b1;
        }

        body {
            background-color: #121212;
            color: var(--steel-gray);
            font-family: 'Cinzel', serif;
        }

        .navbar-custom {
            background: linear-gradient(135deg, var(--animus-dark) 0%, #1a1a1a 100%);
            border-bottom: 2px solid var(--assassin-red) !important;
            padding: 0.5rem 1rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.8);
        }

        .ninja-logo {
            display: flex;
            align-items: center;
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            color: var(--steel-gray) !important;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-decoration: none;
        }

        .sword-icon {
            color: var(--assassin-red);
            font-size: 1.8rem;
            margin-right: 8px;
            transform: rotate(-45deg);
            display: inline-block;
            text-shadow: 0 0 10px var(--assassin-red);
        }

        .nav-link-custom {
            color: var(--blade-silver) !important;
            font-size: 0.85rem;
            font-weight: bold;
            margin: 0 12px;
            transition: all 0.3s ease;
            position: relative;
        }

            .nav-link-custom:hover {
                color: white !important;
                text-shadow: 0 0 10px var(--assassin-red);
            }

        .btn-ninja-login {
            background: transparent;
            border: 1px solid var(--blade-silver);
            color: var(--blade-silver);
            border-radius: 0;
            clip-path: polygon(15% 0, 100% 0, 85% 100%, 0% 100%);
            padding: 6px 20px;
        }

        .btn-ninja-logout {
            background: var(--assassin-red);
            color: white;
            border: none;
            border-radius: 0;
            clip-path: polygon(15% 0, 100% 0, 85% 100%, 0% 100%);
            padding: 6px 20px;
        }

        /* Hover Glow for Cards */
        .card-ninja {
            background-color: #1a1a1a !important;
            border: 1px solid #333 !important;
            transition: 0.4s;
            cursor: pointer;
        }

            .card-ninja:hover {
                transform: translateY(-10px);
                border-color: var(--assassin-red) !important;
                box-shadow: 0 0 20px rgba(142, 0, 0, 0.4);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-custom mb-3">
            <div class="container-fluid">
                <a class="ninja-logo" asp-controller="Home" asp-action="Index">
                    <span class="sword-icon">†</span> NINJA <span style="color:var(--assassin-red)">WARRIORS</span>
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Index">THE ARSENAL</a></li>
                        <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="About">THE CREED</a></li>
                        <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Services">FORGE & SALES</a></li>
                        <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Contact">SIGNAL RAJ</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="btn btn-ninja-login me-2" asp-controller="Home" asp-action="LoginForm">IDENTIFY</a></li>
                        <li class="nav-item"><a class="btn btn-ninja-logout" href="#">DESYNCHRONIZE</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted bg-dark mt-5 py-3 text-center" style="border-color: var(--assassin-red) !important;">
        <div class="container">
            <span style="color: var(--blade-silver)">&copy; 2026 - NINJA WARRIORS - </span>
            <a asp-controller="Home" asp-action="Privacy" style="color: var(--assassin-red)">Privacy Protocol</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>